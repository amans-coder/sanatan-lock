<?xml version="1.0" encoding="utf-8"?>
<!--
  Single layout reused for all three overlay variants (prayer / night-lock / morning-gate).
  Views are toggled at runtime by OverlayController. Full-screen + opaque so it covers the
  blocked app, including Recent Apps (paired with TYPE_ACCESSIBILITY_OVERLAY).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlay_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/overlay_bg_default"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <ImageView
            android:id="@+id/deity_image"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginBottom="28dp"
            android:contentDescription="@string/sadhana_accessibility_label"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/mantra_devanagari"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/overlay_default_mantra_dev"
            android:textColor="@color/overlay_text_primary"
            android:textSize="34sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/mantra_translit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/overlay_default_mantra_translit"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:id="@+id/mantra_meaning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/overlay_default_mantra_meaning"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3" />

        <TextView
            android:id="@+id/strict_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:text="@string/overlay_strict_wait"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="16sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/om_button"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="36dp"
            android:text="@string/overlay_om_button"
            android:textColor="@color/overlay_om_tint"
            android:textSize="48sp"
            android:gravity="center"
            android:background="@drawable/om_button_bg"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</FrameLayout>
